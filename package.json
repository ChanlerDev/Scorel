{
  "name": "scorel",
  "version": "0.1.0",
  "description": "Single-user, local-first, desktop LLM agent client",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron .",
    "build": "pnpm build:main && pnpm build:preload && pnpm build:runner && tsc -p tsconfig.renderer.json && pnpm build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:runner": "tsc -p runner/tsconfig.json",
    "build:renderer": "vite build",
    "pack": "node --experimental-strip-types scripts/build.ts",
    "pack:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false node --experimental-strip-types scripts/build.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src runner tests vite.config.ts vitest.config.ts",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "start": "electron dist/main/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}